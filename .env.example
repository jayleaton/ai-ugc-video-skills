# Optional fal.ai key for local Seedance generation.
# Keep real keys in .env, which is ignored by git.
UGC_FAL_API_KEY=

# Cost-conscious defaults for short-form UGC ads.
UGC_SEEDANCE_ENDPOINT=bytedance/seedance-2.0/image-to-video
UGC_SEEDANCE_ASPECT_RATIO=9:16
UGC_SEEDANCE_RESOLUTION=720p

# First cheaper comparison model for image-to-video UGC tests.
UGC_FAL_VIDEO_PROVIDER=kling-o3-standard
UGC_KLING_O3_STANDARD_ENDPOINT=fal-ai/kling-video/o3/standard/image-to-video
